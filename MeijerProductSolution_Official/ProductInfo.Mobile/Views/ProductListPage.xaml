<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ProductInfo.Mobile.Models"
             x:Class="ProductInfo.Mobile.Views.ProductListPage"
             Title="{Binding Title}">
    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12">
        <VerticalStackLayout Grid.Row="0" Spacing="6">
            <Label Text="Product List" FontSize="28" FontAttributes="Bold" />
            <Label Text="Tap a product to view details." FontSize="14" TextColor="#666666" />
            <Button Text="Refresh" Command="{Binding LoadProductsCommand}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            <Label Text="{Binding ErrorMessage}" TextColor="Red" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Products}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ProductSummary">
                    <Border Stroke="#DDDDDD" StrokeThickness="1" Padding="10" Margin="0,6" StrokeShape="RoundRectangle 12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenProductCommand}" CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="80,*" ColumnSpacing="12">
                            <Image Source="{Binding ImageUrl}" HeightRequest="70" WidthRequest="70" Aspect="AspectFit" />
                            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="18" />
                                <Label Text="{Binding Summary}" FontSize="14" TextColor="#555555" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
