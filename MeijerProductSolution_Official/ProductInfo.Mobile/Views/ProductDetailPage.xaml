<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProductInfo.Mobile.Views.ProductDetailPage"
             Title="{Binding Title}">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            <Label Text="{Binding ErrorMessage}" TextColor="Red" />

            <Image Source="{Binding Product.ImageUrl}" HeightRequest="260" Aspect="AspectFit" BackgroundColor="#F5F5F5" />
            <Label Text="{Binding Product.Title, StringFormat='Title: {0}'}" FontSize="24" FontAttributes="Bold" />
            <Label Text="Description:" FontAttributes="Bold" FontSize="18" />
            <Label Text="{Binding Product.Description}" FontSize="16" LineBreakMode="WordWrap" />
            <Label Text="{Binding Product.Price, StringFormat='Price: {0}'}" FontSize="20" FontAttributes="Bold" />
            <Button Text="Add to List / Share" Command="{Binding ShareCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
